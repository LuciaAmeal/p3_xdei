# FIWARE Services Configuration
FIWARE_SERVICE=fiware
FIWARE_SERVICEPATH=/

# Orion-LD Configuration
ORION_HOST=orion-ld
ORION_PORT=1026
ORION_TIMEOUT=10
ORION_RETRIES=3

# QuantumLeap Configuration
QUANTUMLEAP_HOST=quantumleap
QUANTUMLEAP_PORT=8668
QUANTUMLEAP_TIMEOUT=10
QUANTUMLEAP_RETRIES=3

# MQTT Configuration
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TIMEOUT=5
MQTT_KEEPALIVE=60

# CrateDB Configuration (for reference, not directly used by backend)
CRATEDB_HOST=crate
CRATEDB_PORT=4200

# Application Configuration
LOG_LEVEL=INFO
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
